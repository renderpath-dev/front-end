{
  "name": "vue-typescript-learning-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "vue-tsc --noEmit && vite build",
    "build:analyze": "vue-tsc --noEmit && vite build --mode analyze",
    "preview": "vite preview",
    "verify:dist": "node src/learning/vue/chapter-11-production-deployment/scripts/verifyDistFiles.mjs",
    "verify:env": "node src/learning/vue/chapter-11-production-deployment/scripts/verifyEnvExposure.mjs",
    "ci:local": "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e && npm run build",
    "ci:production": "npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run verify:dist"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,cjs,json,md,css}": [
      "prettier --write"
    ],
    "*.{ts,vue,js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  }
}
